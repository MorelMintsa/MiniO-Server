# Public bindings. Keep 127.0.0.1 behind a reverse proxy; use 0.0.0.0 only when intentionally exposed.
MINIO_API_BIND=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_BIND=127.0.0.1
MINIO_CONSOLE_PORT=9001

# MinIO root account. Replace these before starting the stack.
MINIO_ROOT_USER=change-this-root-user
MINIO_ROOT_PASSWORD=change-this-root-password-min-12-chars

# Comma-separated bucket list. Data lands in minio-data/data/<bucket>.
MINIO_BUCKETS=app-data,backups,logs

# Optional hardening/default bucket features.
MINIO_ENABLE_VERSIONING=true
MINIO_BUCKET_OBJECT_LOCK=false
# Example: 10GiB, 500MiB, 1TiB. Leave empty for no quota.
MINIO_BUCKET_QUOTA=

# Optional application user restricted to MINIO_BUCKETS.
MINIO_APP_USER=app-service
MINIO_APP_PASSWORD=change-this-app-password-min-12-chars

# Optional external URLs when running behind HTTPS reverse proxy.
# MINIO_SERVER_URL=https://s3.example.com
# MINIO_BROWSER_REDIRECT_URL=https://minio.example.com

# Optional manual image override. Leave unset to follow docker-compose.yml defaults.
# MINIO_VERSION=RELEASE.2025-09-07T16-13-09Z-cpuv1
# MINIO_MC_VERSION=RELEASE.2025-08-13T08-35-41Z-cpuv1
